<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8">
  <title>~/folders -- SS</title>
  <link rel="stylesheet" href="/public/style.css">
</head>

<body>
  <%- include('../partials/shellbar') %>
  <div class="wrap">
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert"><%= error %></div>
    <% } %>

    <div class="panel">
      <div class="panel-title"><span class="sigil">$</span> ls -la ~/</div>
      <div class="panel-body">
        <ul class="ls-list">
          <% folders.forEach(folder => { %>
          <li class="is-dir">
            <span class="perm">drwxr-xr-x</span>
            <span class="name"><a href="/folders/<%= folder.id %>"><%= folder.name %></a></span>
          </li>
          <% }) %>
        </ul>
        <% if (folders.length === 0) { %>
        <p class="empty-note">no folders found</p>
        <% } %>
      </div>
    </div>

    <div class="panel">
      <div class="panel-title"><span class="sigil">$</span> mkdir --new</div>
      <div class="panel-body">
        <a class="btn" href="/folders/new">+ New Folder</a>
      </div>
    </div>

    <div class="panel">
      <div class="panel-title"><span class="sigil">$</span> upload --file ~/</div>
      <div class="panel-body">
        <form action="/files" method="POST" enctype="multipart/form-data">
          <div class="field">
            <label>Select file</label>
            <input type="file" name="file" required>
          </div>
          <button type="submit" class="primary">Upload</button>
        </form>
      </div>
    </div>

    <div class="panel">
      <div class="panel-title"><span class="sigil">$</span> ls -la ~/ --files</div>
      <div class="panel-body">
        <ul class="ls-list">
          <% files.forEach(file => { %>
          <li class="is-file">
            <span class="perm">-rw-r--r--</span>
            <span class="name"><a href="/files/<%= file.id %>"><%= file.name %></a></span>
            <span class="size"><%= (file.size / 1024).toFixed(0) %>K</span>
          </li>
          <% }) %>
        </ul>
        <% if (files.length === 0) { %>
        <p class="empty-note">no files found</p>
        <% } %>
      </div>
    </div>

    <div class="term-footer">--- EOF ---</div>
  </div>
</body>

</html>