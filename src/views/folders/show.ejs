<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8">
  <title><%= folder.name %> -- SS</title>
  <link rel="stylesheet" href="/public/style.css">
</head>

<body>
  <%- include('../partials/shellbar', { shellPath: '/folders/' + folder.name }) %>
  <div class="wrap">
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert"><%= error %></div>
    <% } %>

    <div class="breadcrumb">
      <a href="/folders">~</a>
      <% breadcrumb.forEach(crumb => { %>
      <span class="sep">/</span>
      <a href="/folders/<%= crumb.id %>"><%= crumb.name %></a>
      <% }) %>
    </div>

    <% if (typeof shareLink !== 'undefined' && shareLink) { %>
    <div class="alert info">link generated — copy it below</div>
    <% } %>

    <div class="panel">
      <div class="panel-title"><span class="sigil">$</span> stat <%= folder.name %></div>
      <div class="panel-body">
        <div class="actions">
          <a class="btn" href="/folders/<%= folder.id %>/edit">Rename</a>
          <form action="/folders/<%= folder.id %>?_method=DELETE" method="POST">
            <button type="submit" class="danger" onclick="return confirm('Delete this folder and everything in it?')">rm -rf</button>
          </form>
          <a class="btn" href="/folders/new?parentId=<%= folder.id %>">+ New Subfolder</a>
        </div>
      </div>
    </div>

    <div class="panel">
      <div class="panel-title"><span class="sigil">$</span> upload --file ./</div>
      <div class="panel-body">
        <form action="/files" method="POST" enctype="multipart/form-data">
          <input type="hidden" name="folderId" value="<%= folder.id %>">
          <div class="field">
            <label>Select file</label>
            <input type="file" name="file" required>
          </div>
          <button type="submit" class="primary">Upload</button>
        </form>
      </div>
    </div>

    <div class="panel">
      <div class="panel-title"><span class="sigil">$</span> ls -la ./<%= folder.name %></div>
      <div class="panel-body">
        <ul class="ls-list">
          <% folder.children.forEach(child => { %>
          <li class="is-dir">
            <span class="perm">drwxr-xr-x</span>
            <span class="name"><a href="/folders/<%= child.id %>"><%= child.name %></a></span>
          </li>
          <% }) %>
          <% folder.files.forEach(file => { %>
          <li class="is-file">
            <span class="perm">-rw-r--r--</span>
            <span class="name"><a href="/files/<%= file.id %>"><%= file.name %></a></span>
            <span class="size"><%= (file.size / 1024).toFixed(0) %>K</span>
          </li>
          <% }) %>
        </ul>
        <% if (folder.children.length === 0 && folder.files.length === 0) { %>
        <p class="empty-note">directory empty</p>
        <% } %>
      </div>
    </div>

    <div class="panel">
      <div class="panel-title"><span class="sigil">$</span> share --folder --ttl</div>
      <div class="panel-body">
        <% if (typeof shareLink !== 'undefined' && shareLink) { %>
        <div class="share-readout"><%= shareLink %></div>
        <% } %>
        <form action="/shared-links" method="POST">
          <input type="hidden" name="folderId" value="<%= folder.id %>">
          <div class="field">
            <label>Duration</label>
            <select name="duration">
              <option value="1d">1d</option>
              <option value="7d">7d</option>
              <option value="30d">30d</option>
            </select>
          </div>
          <button type="submit" class="primary">Generate link</button>
        </form>
      </div>
    </div>

    <div class="term-footer">--- EOF ---</div>
  </div>
</body>

</html>